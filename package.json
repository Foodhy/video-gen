{
  "name": "video-gen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n SERVER,WEB -c magenta,cyan \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun --watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "bash start.sh",
    "stop": "bash stop.sh",
    "serve": "bun server/index.ts",
    "test": "bun test",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "bun-types": "^1.3.14",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
